        "jsCode": "const start = $('Start').item;\nconst previous = $('Lire Bilan Patrimonial').item.json.data;\nconst updated = $json.choices[0].message.content;\nconst now = $('Prepare Query').item.json.now;\n\n// On découpe par expression régulière pour gérer tous les types de sauts de ligne\n// .filter(line => line.trim() !== \"\") est optionnel : \n// gardez-le si vous voulez ignorer les lignes vides.\nconst lineCountPrevious = previous.split(/\\r\\n|\\r|\\n/).length;\nconst lineCountUpdated = updated.split(/\\r\\n|\\r|\\n/).length;\nconst delta = (lineCountUpdated - lineCountPrevious);\nconst success = delta > -3;\nconst message = success ? `✅ Bilan sauvegardé le ${now} - ${lineCountUpdated} lines` :  `❌ Erreur de construction du bilan consolidé ! (${delta} lines)`;\n\nreturn {\n  \"message\": message,\n  \"sessionId\": start.json.sessionId,\n  \"channel\": start.json.channel || \"telegram\",\n  \"mode\": start.json.mode || \"text\",\n  \"data\": updated,\n  \"success\": success,\n  \"fileId\": $('Lire Bilan Patrimonial').item.json.fileId\n};"
